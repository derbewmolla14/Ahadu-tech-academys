# MongoDB Atlas (required — no localhost default). Paste your Atlas SRV URI.
# Atlas → Connect → Drivers → Connection string (replace USER, PASSWORD, cluster, db).
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/YOUR_DB?retryWrites=true&w=majority

# Optional mongoose connection tuning (Atlas / Render)
# MONGO_CONNECT_RETRIES=5
# MONGO_CONNECT_RETRY_DELAY_MS=2500
# MONGO_SERVER_SELECTION_MS=15000

# JWT signing secret — use a long random string in production
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=7d

# Local: match Vite proxy (frontend/vite.config.js). Render: omit — platform sets PORT automatically.
PORT=5002

# Listen address (Render/Docker-safe default); change only if you know you need another bind.
HOST=0.0.0.0
NODE_ENV=development

# Used in password-reset email links — your Vite dev server URL by default
FRONTEND_URL=http://localhost:5173

# Set to absolute public API URL in production only (e.g. https://api.example.com).
# Leave empty in dev when using relative /uploads paths + Vite proxy.
SERVER_PUBLIC_URL=

# SMTP (leave empty locally — reset URLs are logged to the backend console instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Ahadu Tech Academy <noreply@example.com>"

# Required on the signup form when role Admin is selected; leave unset to disallow admin signup
ADMIN_INVITE_CODE=

# --- Render.com / production ---
# PORT is injected by Render ($PORT); local dev uses PORT=5002 matching Vite proxy.
# FRONTEND_URL = deployed SPA URL (password reset emails).
# SERVER_PUBLIC_URL = https://your-service.onrender.com (avatars /uploads URLs in JSON).
# CLIENT_ORIGINS = comma-separated allowed browser origins if you restrict CORS.
